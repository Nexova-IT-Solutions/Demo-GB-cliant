generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  directUrl    = env("DIRECT_URL")
  relationMode = "prisma"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  open_id           String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id                String              @id @default(cuid())
  name              String?
  email             String?             @unique
  emailVerified     DateTime?
  image             String?
  password          String?
  isActive          Boolean             @default(true)
  role              Role                @default(USER)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  privileges        String[]            @default([])
  templateId        String?
  customPermissions Json?
  phoneNumber       String?
  comments          String?
  addressLine1      String?
  addressLine2      String?
  city              String?
  state             String?
  zipCode           String?
  country           String?
  loginStartTime    String?
  loginEndTime      String?
  hireDate          DateTime?
  birthday          DateTime?
  employeeNumber    String?             @unique
  language          String              @default("en")
  canOverridePrices Boolean             @default(false)
  maxDiscount       Float               @default(0)
  commissionRate    Float               @default(0)
  commissionMethod  String?
  outstandingBalance Float              @default(0)
  accounts          Account[]
  addresses         Address[]
  orders            Order[]
  sessions          Session[]
  cart              Cart?
  template          PermissionTemplate? @relation(fields: [templateId], references: [id])
  reviews           Review[]
  purchasedGiftCards GiftCard[]           @relation("GiftCardPurchaser")
  posShifts         PosShift[]
  returnRequests    ReturnRequest[]
  statusHistories   OrderStatusHistory[]
  ledgerEntries     CustomerLedger[]
}

enum LedgerTransactionType {
  DEBIT
  CREDIT
}

model CustomerLedger {
  id            String                @id @default(cuid())
  userId        String
  amount        Float
  type          LedgerTransactionType
  description   String
  orderId       String?
  paymentMethod String?
  createdAt     DateTime              @default(now())

  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([createdAt])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  token   String   @unique
  email   String
  expires DateTime

  @@index([email])
  @@index([expires])
}

model Category {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  image       String?
  parentId        String?
  parentCategory  Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  subCategories   Category[] @relation("CategoryHierarchy")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  isActive    Boolean    @default(true)
  isPopular   Boolean    @default(false)
  products    Product[]

  @@index([parentId])
  @@index([isActive])
}

model Occasion {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  image       String?
  isActive    Boolean   @default(true)
  color       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  isPopular   Boolean   @default(false)
  products    Product[] @relation("OccasionToProduct")

  @@index([isActive])
}

model Recipient {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[] @relation("RecipientToProduct")
}

model Mood {
  id          String        @id @default(cuid())
  name        String        @unique
  slug        String        @unique
  description String?
  icon        String?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  products    ProductMood[]
}

model Discount {
  id          String       @id @default(cuid())
  name        String
  description String?
  value       Float
  type        DiscountType @default(PERCENTAGE)
  isActive    Boolean      @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  products    Product[]
}

model Supplier {
  id            String          @id @default(cuid())
  name          String
  contactName   String
  email         String?
  phoneNumber   String?
  address       String?
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  products      Product[]
  supplyHistory ProductSupply[]
}

model Product {
  id                    String          @id @default(cuid())
  name                  String
  nameAr                String?
  description           String?
  shortDescription      String?         @db.VarChar(250)
  price                 Float
  stock                 Int             @default(0)
  sizes                 String[]        @default([])
  colors                String[]        @default([])
  isActive              Boolean         @default(true)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  categoryId            String?
  productImages         Json
  productVariants       Json
  isNewArrival          Boolean         @default(false)
  isTrending            Boolean         @default(false)
  showInChocolateSection Boolean         @default(false)
  showInSoftToysSection  Boolean         @default(false)
  isTopRated            Boolean         @default(false)
  isBestSeller          Boolean         @default(false)
  salePrice             Float?
  isPremiumGiftBox      Boolean         @default(false)
  discountId            String?
  showInDiscountSection Boolean         @default(false)
  isSpecialTouch        Boolean         @default(false)
  specialTouchOrder     Int             @default(0)
  costPrice             Float?
  supplierId            String?
  lastSuppliedAt        DateTime?
  sku                   String?         @unique
  isEGiftCard           Boolean         @default(false)
  giftCardValue         Float?
  builderCapacityUnits  Int             @default(1)
  isAvailableInBuilder  Boolean         @default(false)
  itemsInside           GiftBoxItem[]   @relation("BoxToItems")
  parentBoxes           GiftBoxItem[]   @relation("ItemToBoxes")
  category              Category?       @relation(fields: [categoryId], references: [id])
  discount              Discount?       @relation(fields: [discountId], references: [id], onDelete: Restrict)
  supplier              Supplier?       @relation(fields: [supplierId], references: [id])
  moods                 ProductMood[]
  supplyHistory         ProductSupply[]
  occasions             Occasion[]      @relation("OccasionToProduct")
  recipients            Recipient[]     @relation("RecipientToProduct")
  reviews               Review[]
  averageRating         Float           @default(0)
  reviewCount           Int             @default(0)
  orderItems            OrderItem[]

  @@index([categoryId])
  @@index([isNewArrival])
  @@index([isTrending])
  @@index([isTopRated])
  @@index([isBestSeller])
  @@index([showInChocolateSection])
  @@index([showInSoftToysSection])
  @@index([showInDiscountSection])
  @@index([isPremiumGiftBox])
  @@index([isActive])
  @@index([createdAt])
  @@index([name])
  @@index([stock])
}

model ProductSupply {
  id         String   @id @default(cuid())
  productId  String
  supplierId String
  suppliedAt DateTime @default(now())
  costPrice  Float?
  notes      String?
  createdAt  DateTime @default(now())
  product    Product? @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([productId])
  @@index([supplierId])
}

model GiftBoxItem {
  id        String  @id @default(cuid())
  boxId     String
  itemId    String
  quantity  Int     @default(1)
  sortOrder Int     @default(0)
  box       Product @relation("BoxToItems", fields: [boxId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  item      Product @relation("ItemToBoxes", fields: [itemId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@unique([boxId, itemId])
  @@index([boxId])
  @@index([itemId])
}

model ProductMood {
  productId String
  moodId    String
  mood      Mood    @relation(fields: [moodId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@id([productId, moodId])
  @@index([moodId])
}

model GiftCard {
  id                 String               @id @default(cuid())
  code               String               @unique
  barcode            String?              @unique
  initialValue       Float
  balance            Float
  currency           String               @default("LKR")
  image              String?
  isActive           Boolean              @default(false)
  expiresAt          DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  heldByOrderId      String?
  heldUntil          DateTime?
  isPhysical         Boolean              @default(false)
  type               GiftCardType         @default(DIGITAL)
  status             GiftCardStatus       @default(DISABLED)
  purchasedInOrderId String?
  purchasedInOrder   Order?               @relation("PurchasedGiftCards", fields: [purchasedInOrderId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  recipientEmail    String?
  recipientName     String?
  senderName        String?
  personalMessage   String?
  purchasedByUserId String?
  purchasedByUser   User?     @relation("GiftCardPurchaser", fields: [purchasedByUserId], references: [id])
  orderId           String?
  order             Order?    @relation("GiftCardOrder", fields: [orderId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  orderItemId       String?
  orderItem         OrderItem? @relation(fields: [orderItemId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  sentAt            DateTime?
  deliveryStatus    GiftCardDeliveryStatus @default(PENDING)
  redemptions        GiftCardRedemption[]
  orders             Order[]              @relation("AppliedGiftCards")

  @@index([barcode])
}

model GiftCardDenomination {
  id        String   @id @default(cuid())
  value     Float    @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GiftCardRedemption {
  id         String             @id @default(cuid())
  giftCardId String
  orderId    String
  amount     Float
  redeemedAt DateTime           @default(now())
  channel    RedemptionChannel  @default(WEB)
  giftCard   GiftCard           @relation(fields: [giftCardId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  order      Order              @relation(fields: [orderId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([giftCardId])
  @@index([orderId])
}

enum RedemptionChannel {
  WEB
  POS
}

model PermissionTemplate {
  id          String   @id @default(cuid())
  name        String   @unique
  permissions Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

model Address {
  id           String      @id @default(uuid())
  userId       String
  type         AddressType
  contactName  String
  phoneNumber  String
  addressLine1 String
  addressLine2 String?
  city         String
  province     String?     // Added string field for customer profiles
  postalCode   String
  isDefault    Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isDefault])
}

model PromoBanner {
  id             String   @id @default(cuid())
  key            String   @unique
  imageUrl       String   @default("")
  images         String[] @default([])
  slideInterval  Int      @default(3000)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isActive])
}

model PaymentGateway {
  id        String        @id @default(cuid())
  name      PaymentMethod @unique
  mode      GatewayMode   @default(SANDBOX)
  config    Json?
  isActive  Boolean       @default(true)
  updatedAt DateTime      @updatedAt
  feeType   FeeType       @default(NONE)
  feeValue  Float         @default(0)
}

model ShippingConfig {
  id                     String   @id @unique @default("default")
  deliveryFee            Float    @default(350)
  freeDeliveryThreshold  Float    @default(5000)
  isFreeDeliveryEnabled  Boolean  @default(true)
  expressDeliveryFee     Float    @default(650)
  isDeliveryEnabled      Boolean  @default(true)
  deliveryNote           String?
  updatedAt              DateTime @updatedAt
  hideOutOfStockProducts Boolean  @default(false)
  hideEmptyCategories    Boolean  @default(false)
  currency               String   @default("LKR")
}

model Province {
  id        String   @id @default(cuid())
  name      String   @unique // e.g., "Southern Province"
  isActive  Boolean  @default(true)
  cities    City[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model City {
  id         String   @id @default(cuid())
  name       String   // e.g., "Galle"
  provinceId String
  province   Province @relation(fields: [provinceId], references: [id], onDelete: Cascade)
  fee        Float    @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([name, provinceId])
  @@index([provinceId])
  @@index([isActive])
  @@index([name])
}


model GiftWrap {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id                    String               @id @default(cuid())
  orderNumber           String               @unique
  userId                String
  customerName          String
  customerEmail         String
  customerPhone         String
  shippingAddress       Json
  shippingProvince      String?
  shippingCity          String?
  subtotal              Float
  deliveryFee           Float
  freeDeliveryThreshold Float
  total                 Float
  refundedAmount        Float                @default(0)
  orderStatus           OrderStatus          @default(PENDING)
  paymentMethod         PaymentMethod        @default(COD)
  paymentStatus         PaymentStatus        @default(PENDING)
  paymentReference      String?
  trackingNumber        String?
  paymentAttemptedAt    DateTime?
  paymentConfirmedAt    DateTime?
  gatewayResponse       Json?
  webhookVerified       Boolean              @default(false)
  giftMessage           String?
  giftWrapping          Boolean              @default(false)
  noteStyle             String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  bankAccountId         String?
  bankAccount           BankAccount?         @relation(fields: [bankAccountId], references: [id])
  billingAddress        Json?
  giftWrapId            String?
  giftWrapName          String?
  giftWrapPrice         Float?               @default(0)
  isGift                Boolean              @default(false)
  recipientName         String?
  recipientEmail        String?
  recipientPhone        String?
  revealSender          Boolean              @default(true)
  senderName            String?
  senderPhone           String?
  suppressInvoice       Boolean              @default(false)
  requestedDeliveryDate DateTime?
  internalNotes         String?
  appliedGiftCardId     String?
  giftCardDeduction     Float                @default(0)
  remainingPayable      Float?
  paymentFee            Float                @default(0)
  orderSource           OrderSource          @default(WEB)
  orderType             OrderType            @default(STANDARD)
  byobData              Json?
  isBYOB                Boolean              @default(false)
  shiftId               String?
  shift                 PosShift?            @relation("LegacyOrderToPosShift", fields: [shiftId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  posShiftId            String?
  posShift              PosShift?            @relation("OrderToPosShift", fields: [posShiftId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  giftCardRedemptions   GiftCardRedemption[]
  appliedGiftCard       GiftCard?            @relation("AppliedGiftCards", fields: [appliedGiftCardId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  purchasedGiftCards    GiftCard[]           @relation("PurchasedGiftCards")
  giftCardsIssued       GiftCard[]           @relation("GiftCardOrder")
  user                  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  items                 OrderItem[]
  statusHistory         OrderStatusHistory[]
  returnRequest         ReturnRequest?
  itemReturns           OrderItemReturn[]
  reviews               Review[]

  @@index([userId])
  @@index([orderStatus])
  @@index([paymentStatus])
  @@index([createdAt])
  @@index([shiftId])
  @@index([posShiftId])
  @@index([orderSource])
  @@index([isBYOB])
  @@index([shippingProvince])
  @@index([shippingCity])
}

model OrderStatusHistory {
  id              String      @id @default(cuid())
  orderId         String
  status          OrderStatus
  note            String?
  changedByUserId String?
  changedByName   String?
  createdAt       DateTime    @default(now())
  order           Order       @relation(fields: [orderId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  changedByUser   User?       @relation(fields: [changedByUserId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([orderId, createdAt])
  @@index([changedByUserId])
}

model OrderItem {
  id            String   @id @default(cuid())
  orderId       String
  productId     String
  productName   String
  productNameAr String?
  productImage  String?
  quantity      Int
  unitPrice     Float
  salePrice     Float?
  subtotal      Float
  returnedQuantity Int     @default(0)
  discountId    String?
  discountName  String?
  discountValue Float?
  sku           String?   @default("")
  variantDetails Json?
  isCustomBox   Boolean  @default(false)
  customBoxConfig Json?
  parentBoxId   String?
  parentBox     OrderItem?  @relation("BoxItems", fields: [parentBoxId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  childItems    OrderItem[] @relation("BoxItems")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  product       Product?  @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  giftCards     GiftCard[]
  returns       OrderItemReturn[]

  @@index([orderId])
  @@index([productId])
  @@index([orderId, productId])
  @@index([productId, createdAt])
  @@index([parentBoxId])
}

model OrderItemReturn {
  id            String    @id @default(cuid())
  orderItemId   String
  orderId       String
  quantity      Int
  refundAmount  Float
  reason        String?   @db.Text
  restocked     Boolean   @default(true)
  createdAt     DateTime  @default(now())

  orderItem     OrderItem @relation(fields: [orderItemId], references: [id])
  order         Order     @relation(fields: [orderId], references: [id])
  
  @@index([orderItemId])
  @@index([orderId])
}

model BankAccount {
  id            String   @id @default(cuid())
  bankName      String
  accountName   String
  accountNumber String
  branchName    String?
  instructions  String?  @db.Text
  isActive      Boolean  @default(true)
  orders        Order[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
  POS_ADMIN
  STOREFRONT_ADMIN
  PRODUCT_MANAGER
  CUSTOM_ROLE
  DEV_ADMIN
}

enum AddressType {
  BILLING
  DELIVERY
  STAFF_PERMANENT
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
  CONFIRMED
  PACKED
  READY_TO_SHIP
}

enum PaymentMethod {
  COD
  DIRECTPAY
  MINTPAY
  BANK_TRANSFER
  GIFT_CARD
  POS_CASH
  POS_CARD
  POS_GIFT_CARD
  POS_SPLIT
  CREDIT_CARD
  POS_MOBILE_TRANSFER
  POS_CREDIT
  DEBIT_CARD
  CASH
  GIFT_VOUCHER
}

enum OrderSource {
  WEB
  POS
  BYOB
}

enum GatewayMode {
  SANDBOX
  LIVE
}

enum FeeType {
  NONE
  FIXED
  PERCENTAGE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum GiftCardType {
  DIGITAL
  PRINTED
}

enum GiftCardStatus {
  AVAILABLE
  USED
  DISABLED
}

model Review {
  id         String       @id @default(cuid())
  productId  String
  userId     String
  orderId    String?
  rating     Int // 1–5 stars
  comment    String?      @db.Text
  images     String[]     @default([])
  status     ReviewStatus @default(PENDING)
  approvedAt DateTime?
  approvedBy String? // userId of the PM who approved
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  product Product? @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@unique([orderId, productId, userId])
  @@index([productId])
  @@index([userId])
  @@index([status])
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum GiftCardDeliveryStatus {
  PENDING
  SENT
  FAILED
}

model ReturnRequest {
  id        String       @id @default(cuid())
  orderId   String       @unique
  userId    String
  reason    String       @db.Text
  status    ReturnStatus @default(PENDING)
  adminNote String?      @db.Text
  images    String[]     @default([])
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  user  User  @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([userId])
  @@index([status])
}

enum ReturnStatus {
  PENDING
  ACCEPTED
  REJECTED
  REFUNDED
}

// ─── POS Models ─────────────────────────────────────────────

enum PosShiftStatus {
  OPEN
  CLOSED
}

model PosShift {
  id             String           @id @default(cuid())
  operatorId     String
  operator       User             @relation(fields: [operatorId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  status         PosShiftStatus   @default(OPEN)
  openedAt       DateTime         @default(now())
  closedAt       DateTime?
  openingCash    Float            @default(0)
  actualCash     Float?
  expectedCash   Float            @default(0)
  variance       Float            @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  
  // Legacy / Additional fields for compatibility
  startTime      DateTime         @default(now())
  endTime        DateTime?
  startingCash   Float            @default(0)
  expectedCredit Float            @default(0)
  actualCredit   Float?           @default(0)
  cashVariance   Float?           @default(0)
  creditVariance Float?           @default(0)
  expectedDebit  Float            @default(0)
  actualDebit    Float?           @default(0)
  debitVariance  Float?           @default(0)
  expectedGiftCard Float          @default(0)
  actualGiftCard   Float?         @default(0)
  giftCardVariance Float?         @default(0)
  notes          String?
  denomination   Json?
  
  cashCounts     ShiftCashCount[]
  orders         Order[]          @relation("OrderToPosShift")
  legacyOrders   Order[]          @relation("LegacyOrderToPosShift")
  reconciliations ShiftReconciliation[]

  @@index([operatorId])
  @@index([status])
  @@index([openedAt])
  @@index([startTime])
}

model Denomination {
  id        String   @id @default(cuid())
  value     Int      @unique
  isActive  Boolean  @default(true)
  type      CurrencyDenomType @default(NOTE)
  createdAt DateTime @default(now())
}

enum CashCountType {
  OPENING
  CLOSING
}

model ShiftCashCount {
  id              String        @id @default(cuid())
  shiftId         String
  shift           PosShift      @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  denominationVal Int
  quantity        Int
  type            CashCountType

  @@index([shiftId])
}

model CurrencyDenomination {
  id        String              @id @default(cuid())
  value     Float
  label     String
  type      CurrencyDenomType   @default(NOTE)
  isActive  Boolean             @default(true)
  sortOrder Int                 @default(0)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([value, type])
  @@index([isActive])
}

enum CurrencyDenomType {
  NOTE
  COIN
}

enum OrderType {
  STANDARD
  CUSTOM_GIFT_BOX
}

model ShiftReconciliation {
  id             String   @id @default(cuid())
  shiftId        String
  shift          PosShift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  paymentMethod  String   // e.g., "POS_CASH", "CREDIT_CARD", "DEBIT_CARD", "POS_GIFT_CARD"
  systemAmount   Float    @default(0)
  operatorAmount Float    @default(0)
  variance       Float    @default(0)
  status         String   // "MATCHED" or "MISMATCHED"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([shiftId])
  @@index([paymentMethod])
}

model FeatureToggle {
  id        String   @id @default(cuid())
  key       String   @unique
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt
}


model CompanyDetails {
  id             String   @id @default("1")
  companyName    String?
  mobileNumber   String?
  address        String?
  website        String?
  email          String?
  crNumber       String?
  posPrinterName String?
  posPrintMode   String   @default("raw") // "raw" or "raster"
  timezone       String   @default("Asia/Muscat")
  updatedAt      DateTime @updatedAt
}

model ScheduledReport {
  id           String   @id @default(cuid())
  reportType   String   @unique
  enabled      Boolean  @default(false)
  emailAddress String
  ownerName    String
  scheduleTime String   // e.g. "21:00"
  updatedAt    DateTime @updatedAt
}
model EmailLog {
  id           String   @id @default(cuid())
  recipient    String
  subject      String
  status       String   // "SUCCESS", "FAILED"
  errorMessage String?  @db.Text
  createdAt    DateTime @default(now())
}
